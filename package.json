{
  "name": "hello-world-electron",
  "version": "1.3.0",
  "description": "The classic Hello World. Electron flavoured.",
  "license": "MIT",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "npx electron-builder --dir",
    "dist": "npx electron-builder"
  },
  "repository": "https://github.com/rgl/hello-world-electron",
  "author": "Rui Lopes <rgl@ruilopes.com> (http://ruilopes.com)",
  "build": {
    "appId": "com.ruilopes.hello-world-electron",
    "icon": "electron.svg",
    "win": {
      "target": ["nsis", "msi"],
      "signtoolOptions": {
        "certificateFile": "example-code-signing.p12",
        "signingHashAlgorithms": ["sha256"]
      }
    },
    "nsis": {
      "artifactName": "${productName}-setup-${version}.${ext}"
    },
    "msi": {
      "artifactName": "${productName}-${version}.${ext}"
    },
    "files": [
      "*.css",
      "*.html",
      "*.js"
    ]
  },
  "devDependencies": {
    "electron": "^43.1.1",
    "electron-builder": "^26.15.7"
  }
}
